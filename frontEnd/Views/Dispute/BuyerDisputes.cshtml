@model X.PagedList.IPagedList<frontEnd.Models.DisputeResponse>
@using X.PagedList.Mvc.Core
@{
    ViewData["Title"] = "Khiếu Nại Của Tôi";
}

<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen p-6">
    <div class="max-w-5xl mx-auto">

        @* Header *@
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Khiếu Nại Của Tôi</h1>
                <p class="text-gray-500 text-sm mt-1">Danh sách các khiếu nại bạn đã gửi.</p>
            </div>
            <a asp-action="Create" asp-controller="Dispute"
                class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all shadow-md flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14" />
                </svg>
                Tạo khiếu nại mới
            </a>
        </div>

        @* Empty state *@
        @if (Model == null || !Model.Any())
        {
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-12 text-center">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                        stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                </div>
                <h3 class="text-gray-700 font-semibold text-lg mb-1">Chưa có khiếu nại nào</h3>
                <p class="text-gray-400 text-sm mb-6">Bạn chưa gửi khiếu nại nào. Nếu có vấn đề với đơn hàng, hãy tạo mới.
                </p>
                <a asp-action="Create" asp-controller="Dispute"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all">
                    Tạo khiếu nại đầu tiên
                </a>
            </div>
        }
        else
        {
            @* Stats bar *@
            <div class="grid grid-cols-3 gap-4 mb-6">
                @{
                    var total = ViewBag.Total ?? 0;
                    var pending = ViewBag.Pending ?? 0;
                    var resolved = ViewBag.Resolved ?? 0;
                }
                <div class="bg-white rounded-lg border border-gray-200 p-4 text-center shadow-sm">
                    <p class="text-2xl font-bold text-gray-900">@total</p>
                    <p class="text-xs text-gray-500 mt-1">Tổng khiếu nại</p>
                </div>
                <div class="bg-white rounded-lg border border-yellow-200 p-4 text-center shadow-sm">
                    <p class="text-2xl font-bold text-yellow-600">@pending</p>
                    <p class="text-xs text-gray-500 mt-1">Đang xử lý</p>
                </div>
                <div class="bg-white rounded-lg border border-green-200 p-4 text-center shadow-sm">
                    <p class="text-2xl font-bold text-green-600">@resolved</p>
                    <p class="text-xs text-gray-500 mt-1">Đã giải quyết</p>
                </div>
            </div>
            @*Filter by status and submit date*@
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden mb-6">
                <div class="flex items-center gap-4 p-4">
                    <div class="flex items-center gap-2">
                        <label for="statusFilter" class="text-sm font-medium text-gray-700">Trạng thái:</label>
                        <select id="statusFilter" class="border border-gray-200 rounded-lg px-3 py-2 text-sm cursor-pointer outline-none focus:ring-2 focus:ring-blue-500" onchange="filterDisputes()">
                            <option value="all">Tất cả</option>
                            <option value="pending">Đang xử lý</option>
                            <option value="resolved">Đã giải quyết</option>
                            <option value="rejected">Bị từ chối</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-2">
                        <label for="dateFilter" class="text-sm font-medium text-gray-700">Ngày tạo:</label>
                        <select id="dateFilter" class="border border-gray-200 rounded-lg px-3 py-2 text-sm cursor-pointer outline-none focus:ring-2 focus:ring-blue-500" onchange="filterDisputes()">
                            <option value="all">Tất cả</option>
                            <option value="30">30 ngày qua</option>
                            <option value="60">60 ngày qua</option>
                        </select>
                    </div>
                </div>
            </div>
            @* Dispute list *@
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Mã
                                KN</th>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Sản
                                phẩm</th>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                Người bán</th>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Mô
                                tả</th>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Ngày
                                tạo</th>
                            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Hình
                                ảnh</th>
                            <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                Trạng thái</th>
                            <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var dispute in Model)
                        {
                            // Status badge config
                            string badgeClass;
                            string statusLabel;
                            string mappedStatus = "all";
                            var s = dispute.Status?.ToLower() ?? "";
                            if (s == "pending" || s == "open")
                            { badgeClass = "bg-yellow-100 text-yellow-700"; statusLabel = "Đang xử lý"; mappedStatus = "pending"; }
                            else if (s == "resolved" || s == "closed")
                            { badgeClass = "bg-green-100 text-green-700"; statusLabel = "Đã giải quyết"; mappedStatus = "resolved"; }
                            else if (s == "rejected")
                            { badgeClass = "bg-red-100 text-red-700"; statusLabel = "Bị từ chối"; mappedStatus = "rejected"; }
                            else
                            { badgeClass = "bg-gray-100 text-gray-600"; statusLabel = dispute.Status ?? "—"; mappedStatus = s; }

                            <tr class="hover:bg-gray-50 transition-colors dispute-row" data-status="@mappedStatus" data-date="@(dispute.SubmittedDate?.ToString("yyyy-MM-dd"))">
                                <td class="px-5 py-4 font-mono text-gray-700 font-semibold">#@dispute.DisputeId</td>
                                <td class="px-5 py-4">
                                    <p class="font-medium text-gray-800">@(dispute.ProductTitle ?? "—")</p>
                                    <p class="text-xs text-gray-400 mt-0.5">Đơn #@dispute.OrderId</p>
                                </td>
                                <td class="px-5 py-4 text-gray-600">@(dispute.SellerName ?? "—")</td>
                                <td class="px-5 py-4 text-gray-600 max-w-xs">
                                    <p class="line-clamp-2 leading-snug" title="@dispute.Description">
                                        @(dispute.Description ?? "—")
                                    </p>
                                </td>
                                <td class="px-5 py-4 text-gray-600">@dispute.SubmittedDate?.ToString("dd/MM/yyyy")</td>
                                <td class="px-5 py-4 text-gray-600">
                                    @if (dispute.Images != null && dispute.Images.Any())
                                    {
                                        <div class="flex gap-2">
                                            @foreach (var img in dispute.Images)
                                            {
                                                var backendBase = "https://localhost:7290";
                                                var imgSrc = img.FilePath.StartsWith("http") ? img.FilePath : backendBase + img.FilePath;
                                                <a href="@imgSrc" target="_blank" class="block">
                                                    <img src="@imgSrc" alt="Image"
                                                        class="w-16 h-16 object-cover rounded border border-gray-200">
                                                </a>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">Không có ảnh</span>
                                    }
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <span
                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @badgeClass">
                                        @statusLabel
                                    </span>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <button type="button" onclick="openDisputeModal(@dispute.DisputeId)"
                                        class="text-blue-600 hover:text-blue-800 font-medium">Xem chi tiết</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if (Model != null && Model.PageCount > 1)
            {
                <div class="mt-6 flex justify-center">
                    @Html.PagedListPager(Model, page => Url.Action("BuyerDisputes", new { page }),
                        new PagedListRenderOptions
                        {
                            LiElementClasses = new[] { "px-3", "py-2", "border", "border-gray-200", "bg-white", "text-sm", "font-medium", "text-gray-700", "hover:bg-gray-50", "rounded-md", "mx-1" },
                            PageClasses = new[] { "text-gray-700" },
                            ActiveLiElementClass = "bg-blue-600 border-blue-600 text-white",
                            UlElementClasses = new[] { "flex", "items-center", "gap-1" }
                        })
                </div>
            }
        }
    </div>

    <!-- Dispute Detail Modal -->
    <div id="disputeModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <!-- Background overlay -->
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closeModal()"></div>

            <!-- Trick browser into centering modal -->
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

            <!-- Modal panel -->
            <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <div class="flex justify-between items-center border-b pb-3 mb-4">
                        <h3 class="text-xl leading-6 font-bold text-gray-900" id="modal-title">
                            Chi Tiết Khiếu Nại
                        </h3>
                        <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center" onclick="closeModal()">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>  
                        </button>
                    </div>
                    <div id="modalContent">
                        <!-- Content will be loaded here via AJAX -->
                        <div class="flex justify-center py-8">
                            <svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm" onclick="closeModal()">
                        Đóng
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function filterDisputes() {
            var statusFilter = document.getElementById('statusFilter');
            var dateFilter = document.getElementById('dateFilter');
            
            // Only proceed if elements exist
            if (!statusFilter || !dateFilter) return;

            var statusVal = statusFilter.value;
            var dateVal = dateFilter.value;
            var rows = document.querySelectorAll('.dispute-row');
            
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            
            rows.forEach(function(row) {
                var show = true;
                
                // Check status
                if (statusVal !== 'all' && row.getAttribute('data-status') !== statusVal) {
                    show = false;
                }
                
                // Check date
                if (show && dateVal !== 'all') {
                    var dateStr = row.getAttribute('data-date');
                    if (dateStr) {
                        var rowDate = new Date(dateStr);
                        rowDate.setHours(0, 0, 0, 0);
                        var diffTime = today - rowDate; // Use simply difference since today > rowDate expected
                        var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                        
                        if (dateVal === '30' && diffDays > 30) {
                            show = false;
                        } else if (dateVal === '60' && diffDays > 60) {
                            show = false;
                        }
                    }
                }
                
                if (show) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        
        // Initialize filter on load
        document.addEventListener('DOMContentLoaded', filterDisputes);

        function openDisputeModal(disputeId) {
            var modal = document.getElementById('disputeModal');
            var content = document.getElementById('modalContent');
            
            // Show modal
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Prevent scrolling
            
            // Show loading placeholder
            content.innerHTML = '<div class="flex justify-center py-8"><svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg></div>';
            
            // Fetch partially loaded view
            fetch('/Dispute/Details/' + disputeId)
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Network response was not ok");
                    }
                    return response.text();
                })
                .then(html => {
                    content.innerHTML = html;
                })
                .catch(error => {
                    content.innerHTML = '<div class="text-red-600 p-4 text-center">Đã xảy ra lỗi khi tải chi tiết khiếu nại. Vui lòng thử lại.</div>';
                    console.error('Error fetching dispute details:', error);
                });
        }
        
        function closeModal() {
            var modal = document.getElementById('disputeModal');
            modal.classList.add('hidden');
            document.body.style.overflow = ''; // Restore scrolling
        }
    </script>
</body>
