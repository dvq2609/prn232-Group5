@inject IHttpContextAccessor HttpContextAccessor
@{
    var email = HttpContextAccessor.HttpContext.Session.GetString("Email");
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var accountId = HttpContextAccessor.HttpContext.Session.GetInt32("AccountId");
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] </title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0"
        rel="stylesheet" />
    <style type="text/tailwindcss">

    </style>
</head>

<body class="text-gray-800">
    <div class="bg-white border-b border-gray-200">
        <div class="max-w-[1300px] mx-auto px-4 py-2 flex justify-between items-center text-xs">
            <div class="flex items-center space-x-4">
                <span class="text-gray-600">Hi <strong>
                        @if (!string.IsNullOrEmpty(email))
                        {
                            @email
                        }
                        else
                        {
                            <span> <a href="~/Auth/Login">Sign in</a>!</span>
                        }



                    </strong></span>
                @if (!string.IsNullOrEmpty(email))
                {
                    <a class="hover:underline" asp-action="Logout" asp-controller="Auth">Logout</a>
                }
                <a class="hover:underline" href="#">Daily Deals</a>
                <a class="hover:underline" href="#">Help &amp; Contact</a>

                @if (role == "buyer")
                {
                    <a class="hover:underline" asp-action="PurchaseHistory" asp-controller="Feedback">My Purchases</a>
                    <a class="hover:underline" asp-action="MyFeedbacks" asp-controller="Feedback">My Feedbacks</a>
                    <a class="hover:underline" asp-action="BuyerDisputes" asp-controller="Dispute">Buyer Disputes</a>
                }
                else if (role == "seller")
                {
                    <a class="hover:underline" asp-action="SellerOrders" asp-controller="SellerReview">Sold Orders</a>
                    <a class="hover:underline" asp-action="MyReviews" asp-controller="SellerReview">My Reviews</a>
                    <a class="hover:underline" asp-action="SellerDisputes" asp-controller="Dispute">Seller Disputes</a>
                }
                else if (role == "admin")
                {
                    <a class="hover:underline" asp-action="AllDisputes" asp-controller="Dispute">Disputes</a>
                }


            </div>
            <div class="flex items-center space-x-6">
                <a class="hover:underline" href="#">Ship to</a>
                <a class="hover:underline" href="#">Sell</a>
                <a class="flex items-center hover:underline" href="#">Watchlist <span
                        class="material-symbols-outlined text-sm ml-0.5">expand_more</span></a>
                <div class="relative group">
                    <button class="flex items-center hover:underline">My Account <span
                            class="material-symbols-outlined text-sm ml-0.5">expand_more</span></button>
                </div>
                <div class="flex items-center space-x-2">
                    <a class="relative flex items-center hover:underline" asp-controller="Chat" asp-action="Index">
                        <span class="material-symbols-outlined text-lg mr-1">chat</span>
                        <span>Messages</span>
                    </a>
                    @if (!string.IsNullOrEmpty(email))
                    {
                        <!-- Notification Bell -->
                        <div class="relative" id="notification-wrapper">
                            <button id="bell-btn" class="relative flex items-center focus:outline-none">
                                <span class="material-symbols-outlined text-lg">notifications</span>
                                <span id="unread-badge"
                                    class="hidden absolute -top-1.5 -right-1.5 bg-red-500 text-white text-[9px] font-bold rounded-full min-w-[16px] h-4 flex items-center justify-center px-0.5 shadow-sm">0</span>
                            </button>
                            <!-- Dropdown -->
                            <div id="notification-dropdown"
                                class="hidden absolute right-0 top-10 w-80 bg-white border border-gray-200 rounded-lg shadow-xl z-[100]">
                                <div
                                    class="flex justify-between items-center px-4 py-3 border-b border-gray-100 bg-gray-50 rounded-t-lg">
                                    <span class="text-xs font-bold text-gray-700">Thông báo</span>
                                    <button onclick="markAllAsRead()"
                                        class="text-[10px] text-blue-600 hover:text-blue-800 font-medium">Đánh dấu tất cả đã
                                        đọc</button>
                                </div>
                                <div id="notification-list" class="max-h-96 overflow-y-auto divide-y divide-gray-50">
                                    <div class="p-8 text-center text-gray-400 text-xs italic">Đang tải...</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-lg">notifications</span>
                    }
                    <a class="relative" href="#">
                        <span class="material-symbols-outlined text-lg">shopping_cart</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <header class="bg-white sticky top-0 z-50">
        <div class="max-w-[1300px] mx-auto px-4 py-3 flex items-center gap-3">
            <div class="flex-shrink-0">
                <a asp-action="Index" asp-controller="Home">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/1/1b/EBay_logo.svg" alt="eBay"
                        class="h-10 w-auto" />
                </a>
            </div>
            <div class="flex-grow flex items-center min-w-0">
                <div class="relative flex-grow flex items-center border-2 border-gray-800">
                    <input class="w-full py-2 pl-4 pr-2 border-none focus:ring-0 text-sm outline-none"
                        placeholder="Search for anything" type="text" />
                    <div
                        class="border-l border-gray-300 px-3 py-2 flex items-center text-sm text-gray-600 whitespace-nowrap cursor-pointer flex-shrink-0">
                        All Categories
                        <span class="material-symbols-outlined text-sm ml-1">expand_more</span>
                    </div>
                    <button
                        class="bg-blue-600 text-white px-6 py-2 font-medium hover:bg-blue-700 transition-colors flex-shrink-0 flex items-center gap-1">
                        <span class="material-symbols-outlined text-base">search</span>
                        Search
                    </button>
                </div>
            </div>
            <div class="text-xs text-gray-500 hover:underline cursor-pointer flex-shrink-0">Advanced</div>
        </div>
    </header>
    <main class="max-w-[1300px] mx-auto px-4 py-8">
        @RenderBody()
    </main>
    @await Html.PartialAsync("_ChatWidget")
    <footer class="bg-white border-t border-gray-200 pt-12 pb-8 mt-12">
        <div class="max-w-[1300px] mx-auto px-4">
            <div class="grid grid-cols-5 gap-8 mb-12">
                <div>
                    <h4 class="font-bold text-sm mb-4">Shop</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Registration</a></li>
                        <li><a class="hover:underline" href="#">Money Back Guarantee</a></li>
                        <li><a class="hover:underline" href="#">Bidding &amp; buying help</a></li>
                        <li><a class="hover:underline" href="#">Stores</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-sm mb-4">Sell</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Start selling</a></li>
                        <li><a class="hover:underline" href="#">Learn to sell</a></li>
                        <li><a class="hover:underline" href="#">Affiliates</a></li>
                    </ul>
                    <h4 class="font-bold text-sm mb-4 mt-6">Tools &amp; apps</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Developers</a></li>
                        <li><a class="hover:underline" href="#">Security center</a></li>
                        <li><a class="hover:underline" href="#">Site map</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-sm mb-4">Stay connected</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Our Blog</a></li>
                        <li><a class="hover:underline" href="#">Facebook</a></li>
                        <li><a class="hover:underline" href="#">Twitter</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-sm mb-4">About Us</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Company info</a></li>
                        <li><a class="hover:underline" href="#">News</a></li>
                        <li><a class="hover:underline" href="#">Investors</a></li>
                        <li><a class="hover:underline" href="#">Careers</a></li>
                        <li><a class="hover:underline" href="#">Government relations</a></li>
                        <li><a class="hover:underline" href="#">Policies</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-sm mb-4">Help &amp; Contact</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Seller Center</a></li>
                        <li><a class="hover:underline" href="#">Contact Us</a></li>
                        <li><a class="hover:underline" href="#">Returns</a></li>
                    </ul>
                    <h4 class="font-bold text-sm mb-4 mt-6">Community</h4>
                    <ul class="space-y-2 text-xs text-gray-600">
                        <li><a class="hover:underline" href="#">Announcements</a></li>
                        <li><a class="hover:underline" href="#">Discussion boards</a></li>
                        <li><a class="hover:underline" href="#">Answer center</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="text-[10px] text-gray-500 max-w-3xl">
                    Copyright © 1995-2024 Market Inc. All Rights Reserved.
                    <a class="underline ml-2" href="#">Accessibility</a>,
                    <a class="underline ml-2" href="#">User Agreement</a>,
                    <a class="underline ml-2" href="#">Privacy</a>,
                    <a class="underline ml-2" href="#">Payments Terms of Use</a>,
                    <a class="underline ml-2" href="#">Cookies</a>,
                    <a class="underline ml-2" href="#">Your Privacy Choices</a> and
                    <a class="underline ml-2" href="#">AdChoice</a>
                </div>
                <div
                    class="flex items-center space-x-2 text-xs font-medium border border-gray-200 px-3 py-1 rounded cursor-pointer hover:bg-gray-50">
                    <img alt="USA" class="w-5 h-auto"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuB1CzCqo4APKD8APnEXsDNxNwH2IhYzcbuf_fg5iPi9JbYWmH_jmj0Ryn4lL0sEIenM-gCV1xFFaTpD-OAFda9gJo4AShcVC0B1M4vCs_myaawAsREoftnSOKtnSOQvJyntAWbIze1f4IhJ45ZGmB1XQgjYw8BxVJ6vCoUL4-WN-eXtVjEeuM2XwVL6rHCi5JeGuZwrhtpdDvbrUfpioR2Ufq9C26BitQyG2RAaif8_0LwWgOT31VQxVmDlbBjQSXE5pzscYYCFqCN6" />
                    <span>United States</span>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const bellBtn = document.getElementById('bell-btn');
            const dropdown = document.getElementById('notification-dropdown');
            const unreadBadge = document.getElementById('unread-badge');
            const notificationList = document.getElementById('notification-list');
            const wrapper = document.getElementById('notification-wrapper');

            if (!bellBtn) return;

            // Update unread count immediately and then every 30s
            updateUnreadCount();
            setInterval(updateUnreadCount, 30000);

            // Toggle dropdown
            bellBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                dropdown.classList.toggle('hidden');
                if (!dropdown.classList.contains('hidden')) {
                    fetchNotifications();
                }
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function (e) {
                if (wrapper && !wrapper.contains(e.target)) {
                    dropdown.classList.add('hidden');
                }
            });

            async function updateUnreadCount() {
                try {
                    const response = await fetch('/Notification/UnreadCount');
                    if (response.ok) {
                        const count = await response.json();
                        if (count > 0) {
                            unreadBadge.textContent = count > 99 ? '99+' : count;
                            unreadBadge.classList.remove('hidden');
                        } else {
                            unreadBadge.classList.add('hidden');
                        }
                    }
                } catch (err) {
                    console.error('Failed to fetch unread count:', err);
                }
            }

            async function fetchNotifications() {
                try {
                    notificationList.innerHTML = '<div class="p-8 text-center text-gray-400 text-xs italic animate-pulse">Đang tải...</div>';
                    const response = await fetch('/Notification/GetNotifications');
                    if (response.ok) {
                        const notifications = await response.json();
                        renderNotifications(notifications);
                    } else {
                        notificationList.innerHTML = '<div class="p-8 text-center text-red-400 text-xs">Không thể tải thông báo.</div>';
                    }
                } catch (err) {
                    notificationList.innerHTML = '<div class="p-8 text-center text-red-500 text-xs">Lỗi hệ thống.</div>';
                }
            }

            function renderNotifications(notifications) {
                if (!notifications || notifications.length === 0) {
                    notificationList.innerHTML = '<div class="p-10 text-center text-gray-400 text-xs">Bạn chưa có thông báo nào.</div>';
                    return;
                }

                notificationList.innerHTML = notifications.map(noti => {
                    const isUnread = !noti.isRead;
                    const dateStr = noti.createdAt || noti.CreatedAt;
                    const redirectLink = noti.redirectUrl || noti.RedirectUrl || '#';
                    const date = new Date(dateStr).toLocaleString('vi-VN', {
                        hour: '2-digit',
                        minute: '2-digit',
                        day: '2-digit',
                        month: '2-digit'
                    });

                    return `
                        <div onclick="handleNotificationClick(${noti.id}, '${redirectLink}')" 
                             class="p-4 hover:bg-blue-50 cursor-pointer transition-colors relative ${isUnread ? 'bg-blue-50/30' : ''}">
                            <div class="flex justify-between items-start gap-3">
                                <div class="flex-grow">
                                    <p class="text-[13px] ${isUnread ? 'font-semibold text-gray-900' : 'text-gray-600'} leading-tight">
                                        ${noti.message}
                                    </p>
                                    <span class="text-[10px] text-gray-400 mt-1 block">${date}</span>
                                </div>
                                ${isUnread ? '<div class="w-2 h-2 bg-blue-500 rounded-full mt-1.5 flex-shrink-0"></div>' : ''}
                            </div>
                        </div>
                    `;
                }).join('');
            }
        });

        async function handleNotificationClick(id, link) {
            try {
                await fetch(`/Notification/MarkAsRead?id=${id}`, { method: 'PUT' });
                if (link && link !== '#') {
                    window.location.href = link;
                } else {
                    location.reload();
                }
            } catch (err) {
                console.error('Failed to mark as read:', err);
                if (link && link !== '#') window.location.href = link;
            }
        }

        async function markAllAsRead() {
            try {
                const response = await fetch('/Notification/MarkAllAsRead', { method: 'PUT' });
                if (response.ok) {
                    const badge = document.getElementById('unread-badge');
                    if (badge) badge.classList.add('hidden');

                    // Update current list UI
                    const items = document.querySelectorAll('#notification-list > div');
                    items.forEach(item => {
                        item.classList.remove('bg-blue-50/30');
                        const dot = item.querySelector('.bg-blue-500');
                        if (dot) dot.remove();
                        const p = item.querySelector('p');
                        if (p) {
                            p.classList.remove('font-semibold', 'text-gray-900');
                            p.classList.add('text-gray-600');
                        }
                    });
                }
            } catch (err) {
                console.error('Failed to mark all as read:', err);
            }
        }
    </script>
</body>

</html>

