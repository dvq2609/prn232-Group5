@model List<frontEnd.Models.SellerReviewViewModel>
@{
    ViewData["Title"] = "My Reviews for Buyers";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold mb-1">My Reviews for Buyers</h1>
    <p class="text-sm text-gray-500">Reviews you have left for buyers on your sold orders.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-4 text-sm">
        @TempData["SuccessMessage"]
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-16">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">rate_review</span>
        <p class="text-gray-500 text-lg">You haven't reviewed any buyers yet.</p>
        <a asp-action="SellerOrders" asp-controller="SellerReview"
            class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-blue-700 transition-colors">
            View Sold Orders
        </a>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var review in Model)
        {
            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-sm transition-shadow">
                <div class="flex items-start gap-4">
                    <!-- Product Image -->
                    <div class="w-20 h-20 flex-shrink-0 bg-gray-100 rounded overflow-hidden">
                        @if (!string.IsNullOrEmpty(review.ProductImage))
                        {
                            <img src="~/@review.ProductImage" alt="@review.ProductName"
                                class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-2xl text-gray-400">image</span>
                            </div>
                        }
                    </div>

                    <div class="flex-grow min-w-0">
                        <div class="flex items-start justify-between">
                            <div>
                                <h3 class="font-semibold text-sm">@review.ProductName</h3>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    Buyer: <strong>@review.BuyerName</strong> &middot; Order #@review.OrderId
                                </p>
                            </div>
                            <span class="text-xs text-gray-400 flex-shrink-0">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="mt-3 bg-gray-50 rounded p-3">
                            <p class="text-sm text-gray-700">@review.Comment</p>
                        </div>
                        <div class="mt-2 flex items-center gap-3">
                            <a asp-action="EditReview" asp-controller="SellerReview" asp-route-reviewId="@review.Id"
                                class="text-xs text-blue-600 hover:underline inline-flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">edit</span> Edit
                            </a>
                            <form asp-action="DeleteReview" asp-controller="SellerReview" method="post" class="inline"
                                onsubmit="return confirm('Are you sure you want to delete this review?');">
                                <input type="hidden" name="reviewId" value="@review.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-xs text-red-600 hover:underline inline-flex items-center gap-1">
                                    <span class="material-symbols-outlined text-sm">delete</span> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

