@model frontEnd.Models.CreateSellerReviewViewModel
@{
    ViewData["Title"] = "Review Buyer";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold mb-1">Leave a Review for Buyer</h1>
        <p class="text-sm text-gray-500">Share your experience with this buyer.</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Order Info Card -->
    <div class="border border-gray-200 rounded-lg p-4 flex items-start gap-4 mb-6 bg-gray-50">
        <div class="w-20 h-20 flex-shrink-0 bg-white rounded overflow-hidden border border-gray-200">
            @if (!string.IsNullOrEmpty(Model.ProductImage))
            {
                <img src="~/@Model.ProductImage" alt="@Model.ProductTitle"
                    class="w-full h-full object-cover" />
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl text-gray-400">image</span>
                </div>
            }
        </div>
        <div>
            <h3 class="font-semibold text-sm">@Model.ProductTitle</h3>
            <p class="text-xs text-gray-500 mt-1">Order #@Model.OrderId</p>
            <p class="text-xs text-gray-500 mt-0.5">Buyer: <strong>@Model.BuyerName</strong></p>
        </div>
    </div>

    <!-- Review Form -->
    <form asp-action="LeaveReview" asp-controller="SellerReview" method="post">
        <input type="hidden" asp-for="OrderId" />
        <input type="hidden" asp-for="BuyerId" />
        <input type="hidden" asp-for="BuyerName" />
        <input type="hidden" asp-for="ProductTitle" />
        <input type="hidden" asp-for="ProductImage" />

        <div class="mb-4">
            <label asp-for="Comment" class="block text-sm font-medium text-gray-700 mb-2">
                Your comment about this buyer
            </label>
            <textarea asp-for="Comment" rows="5" maxlength="1000" placeholder="e.g. Great buyer, fast payment, excellent communication..."
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
                id="commentBox"></textarea>
            <div class="flex justify-between mt-1">
                <span asp-validation-for="Comment" class="text-xs text-red-500"></span>
                <span id="charCount" class="text-xs text-gray-400">0 / 1000</span>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                class="bg-blue-600 text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-blue-700 transition-colors">
                Submit Review
            </button>
            <a asp-action="SellerOrders" asp-controller="SellerReview"
                class="bg-gray-200 text-gray-700 px-6 py-2 rounded-full text-sm font-medium hover:bg-gray-300 transition-colors">
                Cancel
            </a>
        </div>
    </form>
</div>

<script>
    const box = document.getElementById('commentBox');
    const counter = document.getElementById('charCount');
    box.addEventListener('input', () => {
        counter.textContent = box.value.length + ' / 1000';
    });
</script>

