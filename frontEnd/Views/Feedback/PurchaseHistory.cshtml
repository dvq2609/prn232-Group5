@model List<frontEnd.Models.OrderViewModel>
@{
    ViewData["Title"] = "Purchase History";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold mb-1">Purchase History</h1>
    <p class="text-sm text-gray-500">View your past orders and leave feedback for delivered items.</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm">
        @TempData["ErrorMessage"]
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-4 text-sm">
        @TempData["SuccessMessage"]
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-16">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">shopping_bag</span>
        <p class="text-gray-500 text-lg">You haven't made any purchases yet.</p>
        <a asp-action="Index" asp-controller="Home"
            class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-blue-700">
            Start Shopping
        </a>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var order in Model)
        {
            <div class="border border-gray-200 rounded-lg p-4 flex items-start gap-4 hover:shadow-sm transition-shadow">
                <!-- Product Image -->
                <div class="w-24 h-24 flex-shrink-0 bg-gray-100 rounded overflow-hidden">
                    @if (!string.IsNullOrEmpty(order.ProductImage))
                    {
                        <img src="~/@order.ProductImage" alt="@order.ProductTitle"
                            class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl text-gray-400">image</span>
                        </div>
                    }
                </div>

                <!-- Order Info -->
                <div class="flex-grow min-w-0">
                    <h3 class="font-semibold text-sm truncate">
                        <a asp-action="Details" asp-controller="Product" asp-route-id="@order.ProductId"
                            class="text-blue-600 hover:underline">@order.ProductTitle</a>
                    </h3>
                    <p class="text-xs text-gray-500 mt-1">
                        Seller: <a asp-action="SellerProfile" asp-controller="Feedback"
                            asp-route-sellerId="@order.SellerId"
                            class="text-blue-600 hover:underline">@order.SellerName</a>
                    </p>
                    <p class="text-xs text-gray-500 mt-0.5">
                        Order #@order.OrderId &middot;
                        @(order.OrderDate?.ToString("MMM dd, yyyy") ?? "N/A")
                    </p>
                    @if (order.TotalPrice.HasValue)
                    {
                        <p class="text-sm font-semibold mt-1">@order.TotalPrice.Value.ToString("N0") VND</p>
                    }
                </div>

                <!-- Status + Action -->
                <div class="flex-shrink-0 text-right">
                    @{
                        var statusColor = order.Status switch
                        {
                            "Delivered" or "delivered" or "Completed" => "text-green-600",
                            "Pending" or "pending" => "text-yellow-600",
                            "Cancelled" or "cancelled" => "text-red-600",
                            _ => "text-gray-600"
                        };
                    }
                    <span class="text-xs font-medium @statusColor">@order.Status</span>

                    @if ((order.Status == "Delivered" || order.Status == "delivered" || order.Status == "Completed")
                   && order.IsCommented != true)
                    {
                        <div class="mt-3">
                            <a asp-action="LeaveFeedback" asp-controller="Feedback"
                                asp-route-orderId="@order.OrderId"
                                class="inline-block bg-blue-600 text-white px-4 py-1.5 rounded-full text-xs font-medium hover:bg-blue-700 transition-colors">
                                Leave Feedback
                            </a>
                        </div>
                    }
                    else if (order.IsCommented == true)
                    {
                        <div class="mt-3">
                            <span class="inline-flex items-center gap-1 text-xs text-green-600 font-medium">
                                <span class="material-symbols-outlined text-sm">check_circle</span>
                                Feedback Left
                            </span>
                            <div class="mt-1">
                                <a asp-action="EditFeedback" asp-controller="Feedback"
                                    asp-route-orderId="@order.OrderId"
                                    class="inline-block text-blue-600 text-xs font-medium hover:underline">
                                    Edit Feedback
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
