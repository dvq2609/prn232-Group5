@model List<frontEnd.Models.FeedbackViewModel>
@{
    ViewData["Title"] = "My Feedbacks";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold mb-1">Feedback Left by You</h1>
    <p class="text-sm text-gray-500">View all the feedback you've left for sellers.</p>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-16">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">rate_review</span>
        <p class="text-gray-500 text-lg">You haven't left any feedback yet.</p>
        <a asp-action="PurchaseHistory" asp-controller="Feedback"
            class="inline-block mt-4 bg-blue-600 text-white px-6 py-2 rounded-full text-sm font-medium hover:bg-blue-700">
            View Purchase History
        </a>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var fb in Model)
        {
            <div class="border border-gray-200 rounded-lg p-4">
                <div class="flex items-start gap-4">
                    <!-- Product Image -->
                    <div class="w-20 h-20 flex-shrink-0 bg-gray-100 rounded overflow-hidden">
                        @if (!string.IsNullOrEmpty(fb.ProductImage))
                        {
                            <img src="~/@fb.ProductImage" alt="@fb.ProductTitle" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-2xl text-gray-400">image</span>
                            </div>
                        }
                    </div>

                    <!-- Feedback Info -->
                    <div class="flex-grow">
                        <div class="flex items-center justify-between">
                            <h3 class="font-semibold text-sm">
                                <a asp-action="Details" asp-controller="Product" asp-route-id="@fb.ProductId"
                                    class="text-blue-600 hover:underline">@(fb.ProductTitle ?? "Item")</a>
                            </h3>
                            <span class="text-xs text-gray-400">@(fb.OrderDate?.ToString("MMM dd, yyyy") ?? "")</span>
                        </div>

                        <p class="text-xs text-gray-500 mt-1">
                            Seller:
                            <a asp-action="SellerProfile" asp-controller="Feedback"
                                asp-route-sellerId="@fb.SellerId"
                                class="text-blue-600 hover:underline">@(fb.SellerName ?? "Unknown")</a>
                            &middot; Order #@fb.OrderId
                        </p>

                        <!-- Stars -->
                        <div class="flex items-center gap-2 mt-2">
                            <div class="flex gap-0.5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="text-sm @(i <= (int)(fb.AverageRating ?? 0) ? "text-yellow-400" : "text-gray-300")">★</span>
                                }
                            </div>
                            <span class="text-xs text-gray-500">@((fb.AverageRating ?? 0).ToString("0.0"))</span>
                        </div>

                        @if (!string.IsNullOrEmpty(fb.Comment))
                        {
                            <p class="text-sm text-gray-700 mt-2">@fb.Comment</p>
                        }

                        <!-- Detail Ratings -->
                        <div class="flex gap-4 mt-2 text-xs text-gray-500">
                            @if (fb.DeliveryOnTime.HasValue)
                            {
                                <span>On time: @fb.DeliveryOnTime/5</span>
                            }
                            @if (fb.ExactSame.HasValue)
                            {
                                <span>As described: @fb.ExactSame/5</span>
                            }
                            @if (fb.Communication.HasValue)
                            {
                                <span>Communication: @fb.Communication/5</span>
                            }
                        </div>

                        <div class="mt-3 flex items-center gap-3">
                            <a asp-action="EditFeedback" asp-controller="Feedback"
                                asp-route-orderId="@fb.OrderId"
                                class="inline-flex items-center gap-1 text-xs text-blue-600 font-medium hover:underline">
                                <span class="material-symbols-outlined text-sm">edit</span>
                                Edit Feedback
                            </a>
                            <form asp-action="DeleteFeedback" asp-controller="Feedback" method="post"
                                class="inline" onsubmit="return confirm('Are you sure you want to delete this feedback?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@fb.OrderId" />
                                <button type="submit"
                                    class="inline-flex items-center gap-1 text-xs text-red-600 font-medium hover:underline">
                                    <span class="material-symbols-outlined text-sm">delete</span>
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
