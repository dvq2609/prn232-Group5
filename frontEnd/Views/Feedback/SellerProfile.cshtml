@model frontEnd.Models.SellerFeedbackProfileViewModel
@{
    ViewData["Title"] = (Model.SellerName ?? "Seller") + " - Feedback Profile";
}

<div class="max-w-4xl mx-auto">
    <!-- Seller Header -->
    <div class="border border-gray-200 rounded-lg p-6 mb-6">
        <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                <span class="text-2xl font-bold text-blue-600">
                    @(Model.SellerName?.Substring(0, 1).ToUpper() ?? "S")
                </span>
            </div>
            <div class="flex-grow">
                <h1 class="text-xl font-bold">@(Model.SellerName ?? "Seller")</h1>
                <div class="flex items-center gap-4 mt-2 text-sm">
                    <span class="text-green-600 font-semibold">@Model.PositiveFeedbackPercent% Positive feedback</span>
                    <span class="text-gray-400">|</span>
                    <span class="text-gray-600">@Model.TotalFeedbacks feedback score</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <!-- Average Rating -->
        <div class="border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-3xl font-bold text-gray-800">@Model.AverageRating.ToString("0.0")</p>
            <div class="flex justify-center gap-0.5 my-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="text-lg @(i <= (int)Math.Round(Model.AverageRating) ? "text-yellow-400" : "text-gray-300")">★</span>
                }
            </div>
            <p class="text-xs text-gray-500">Average Rating</p>
        </div>

        <!-- Positive Rate -->
        <div class="border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-3xl font-bold text-green-600">@Model.PositiveFeedbackPercent%</p>
            <p class="text-xs text-gray-500 mt-2">Positive Feedback</p>
            <p class="text-xs text-gray-400">(@Model.TotalFeedbacks total)</p>
        </div>

        <!-- Total Feedbacks -->
        <div class="border border-gray-200 rounded-lg p-4 text-center">
            <p class="text-3xl font-bold text-gray-800">@Model.TotalFeedbacks</p>
            <p class="text-xs text-gray-500 mt-2">Total Feedbacks</p>
        </div>
    </div>

    <!-- Detailed Seller Ratings -->
    @if (Model.TotalFeedbacks > 0)
    {
        <div class="border border-gray-200 rounded-lg p-6 mb-6">
            <h2 class="font-bold text-base mb-4">Detailed Seller Ratings</h2>
            <div class="space-y-4">
                @{
                    var criteria = new[] {
                        ("Item arrived on time", Model.AvgDeliveryOnTime),
                        ("Item as described", Model.AvgExactSame),
                        ("Seller communication", Model.AvgCommunication)
                    };
                }
                @foreach (var (label, score) in criteria)
                {
                    <div class="flex items-center gap-3">
                        <span class="text-sm text-gray-700 w-48 flex-shrink-0">@label</span>
                        <div class="flex-grow bg-gray-200 rounded-full h-2.5">
                            <div class="bg-blue-600 h-2.5 rounded-full" style="width: @((score / 5.0 * 100).ToString("0"))%"></div>
                        </div>
                        <span class="text-sm font-semibold text-gray-700 w-8 text-right">@score.ToString("0.0")</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Recent Feedbacks -->
    <div class="border border-gray-200 rounded-lg p-6">
        <h2 class="font-bold text-base mb-4">Recent Feedback</h2>

        @if (Model.RecentFeedbacks == null || Model.RecentFeedbacks.Count == 0)
        {
            <p class="text-gray-500 text-sm py-4">No feedback received yet.</p>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var fb in Model.RecentFeedbacks)
                {
                    <div class="border-b border-gray-100 pb-4 last:border-b-0 last:pb-0">
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                                <span class="text-xs font-bold text-gray-600">
                                    @(fb.BuyerName?.Substring(0, 1).ToUpper() ?? "?")
                                </span>
                            </div>
                            <div class="flex-grow">
                                <div class="flex items-center gap-2">
                                    <span class="text-sm font-medium">@(fb.BuyerName ?? "Anonymous")</span>
                                    <div class="flex gap-0.5">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span class="text-xs @(i <= (int)(fb.AverageRating ?? 0) ? "text-yellow-400" : "text-gray-300")">★</span>
                                        }
                                    </div>
                                    <span class="text-xs text-gray-400">@(fb.OrderDate?.ToString("MMM dd, yyyy") ?? "")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(fb.Comment))
                                {
                                    <p class="text-sm text-gray-700 mt-1">@fb.Comment</p>
                                }
                                <p class="text-xs text-gray-400 mt-1">for @(fb.ProductTitle ?? "item")</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
